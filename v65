def _tier_from_composite(score: Optional[float]) -> Optional[str]:
    if score is None:
        return None
    s = float(score)
    if s >= 80.0:
        return 'A'
    if s >= 65.0:
        return 'B'
    if s >= 50.0:
        return 'C'
    if s >= 35.0:
        return 'D Watch'
    return 'Eliminate'

