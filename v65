    last_earn_dt = _extract_last_earnings_date_from_payloads(earnings_surprises_fh or [], earnings_surprises_fmp or [], earnings_report_fmp or [], earnings_cal or {})
    row['_next_earnings_date'] = _extract_next_earnings_date_from_calendar(earnings_cal or {})
    ticker_3d = _compute_3d_post_earnings_return_from_bars(raw_bars, last_earn_dt)
    sector_3d = _compute_3d_post_earnings_return_from_bars(sector_raw_bars, last_earn_dt) if sector_etf_ticker else None
    _merge_row(row, parse_earnings_and_ear_section(earnings_surprises_fh or [], earnings_cal or {}, analyst_estimates or [], earnings_surprises_fmp or [], earnings_report_fmp or [], rev_source, ticker_3d, sector_3d, row.get('market_cap_tier')))
    row['trading_days_since_earnings'] = _exact_trading_days_since_from_bars(raw_bars, row.get('last_earnings_date'))
    _expired_exact = row['trading_days_since_earnings'] is not None and row['trading_days_since_earnings'] > 63
    _insuff = row.get('ear_exempt_reason') == 'insufficient_analyst_coverage'
    row['ear_neutral_flag'] = bool(_expired_exact or _insuff)
    row['ear_exempt_reason'] = 'expired_gt_63d' if _expired_exact else 'insufficient_analyst_coverage' if _insuff else None
    km_ttm = _safe_call(fmp_get_key_metrics_ttm, ticker)
    ratios_ttm = _safe_call(fmp_get_ratios_ttm, ticker)
    km_q = _safe_call(fmp_get_key_metrics_quarter, ticker)
    ratios_q = _safe_call(fmp_get_ratios_quarter, ticker)
    dcf = _safe_call(fmp_get_dcf, ticker)
    cf_annual = _safe_call(fmp_get_cash_flow_annual, ticker)
    cf_ttm = _safe_call(fmp_get_cash_flow_ttm, ticker)
    income_ttm = _safe_call(fmp_get_income_statement_ttm, ticker)
    bal_annual = _safe_call(fmp_get_balance_sheet_annual, ticker)
    sec_cik = _extract_cik_from_fmp(profile or {}, core or {})
    issuer_cusip = _extract_issuer_cusip(profile or {}, core or {}, details or {})
    row['sec_cik'] = sec_cik
    row['_issuer_cusip'] = issuer_cusip
    bal_q = _safe_call(fmp_get_balance_sheet_quarter, ticker)
    _merge_row(row, parse_profitability_section(km_ttm or [], ratios_ttm or [], km_q or [], dcf or [], cf_annual or [], income_ttm or [], bal_annual or [], bal_q or [], cf_ttm or [], ratios_q or []))
    inc_q = _safe_call(fmp_get_income_statement_quarter, ticker)
    _merge_row(row, parse_earnings_quality_section(income_ttm or [], cf_ttm or [], bal_annual or [], bal_q or [], inc_q or [], ticker))
    ev = _safe_call(fmp_get_enterprise_values, ticker)
    _merge_row(row, parse_valuation_section(ratios_ttm or [], km_ttm or [], ev or [], bal_annual or [], income_ttm or [], analyst_estimates or [], row.get('price_to_sales'), row.get('current_price'), bal_q or [], finviz_quote, reported_period_end=reported_period_end))
    scores = _safe_call(fmp_get_financial_scores, ticker)
    _merge_row(row, parse_solvency_section(scores or [], row.get('altman_model_variant'), row.get('days_to_cover'), ticker, bal_q or [], income_ttm or [], short_interest or {}, raw_bars, market_proxy_bars, row.get('current_price'), row.get('market_cap')))
    sec_submissions = _safe_call(sec_get_company_submissions, sec_cik) if sec_cik else None
    insider_tx = _safe_call(finnhub_get_insider_transactions, ticker, (date.today() - timedelta(days=365)).isoformat(), date.today().isoformat())
    def _buy_date_from_insider_row(r: dict[str, Any]) -> Optional[str]:
        return _parse_iso_date(_latest_non_null([r.get('transactionDate'), r.get('filingDate')]))
    _raw_insider_data = _get_nested(insider_tx or {}, 'data') or []
    _raw_insider_data = _raw_insider_data if isinstance(_raw_insider_data, list) else []
    _candidate_buys = sorted([r for r in _raw_insider_data if str(_latest_non_null([r.get('transactionCode'), r.get('transactionType')]) or '').upper() in {'P', 'BUY'}], key=lambda r: _buy_date_from_insider_row(r) or '0000-00-00', reverse=True)
    confirmed_row = None
    confirmed_filing_text = None
    for candidate in _candidate_buys:
        _cand_filing_date = _parse_iso_date(_latest_non_null([candidate.get('filingDate'), candidate.get('transactionDate')]))
        _cand_name = str(candidate.get('name') or candidate.get('personName') or '').strip() or None
        _cand_url = _latest_form4_url_from_submissions(sec_cik, sec_submissions or {}, _cand_filing_date, _cand_name)
        _cand_text = _safe_call(sec_get_filing_text, _cand_url) if _cand_url else None
        if _cand_text and 'OPEN MARKET' in _cand_text.upper():
            confirmed_row = candidate
            confirmed_filing_text = _cand_text
            break
    if confirmed_row is None:
        _filtered_data = [r for r in _raw_insider_data if str(_latest_non_null([r.get('transactionCode'), r.get('transactionType')]) or '').upper() not in {'P', 'BUY'}]
    else:
        _cutoff = _buy_date_from_insider_row(confirmed_row)
        _filtered_data = []
        _confirmed_inserted = False
        for r in _raw_insider_data:
            _code = str(_latest_non_null([r.get('transactionCode'), r.get('transactionType')]) or '').upper()
            if _code in {'P', 'BUY'}:
                _rdate = _buy_date_from_insider_row(r)
                if _rdate and _cutoff and _rdate > _cutoff:
                    continue
                if (_rdate == _cutoff) and (r is confirmed_row) and not _confirmed_inserted:
                    _filtered_data.append(r)
                    _confirmed_inserted = True
                    continue
                if (_rdate == _cutoff) and (r is not confirmed_row) and not _confirmed_inserted:
                    _filtered_data.append(confirmed_row)
                    _confirmed_inserted = True
                if r is confirmed_row:
                    if not _confirmed_inserted:
                        _filtered_data.append(r)
                        _confirmed_inserted = True
                    continue
            _filtered_data.append(r)
        if confirmed_row is not None and not _confirmed_inserted:
            _filtered_data.insert(0, confirmed_row)
    insider_tx_for_parser = {'data': _filtered_data}
    filing_text = confirmed_filing_text
    shares_outstanding = _latest_non_null([
        _to_float(_get_nested(details or {}, 'results', 'share_class_shares_outstanding')),
        _to_float(_first_list_item(profile or {}).get('sharesOutstanding')) if isinstance(_first_list_item(profile or {}), dict) else None,
        _to_float(_first_list_item(core or {}).get('sharesOutstanding')) if isinstance(_first_list_item(core or {}), dict) else None,
        None if row.get('market_cap') in (None, 0) or row.get('current_price') in (None, 0) else float(row['market_cap']) / float(row['current_price']),
    ])
    row['_shares_outstanding_estimate'] = shares_outstanding
    _merge_row(row, parse_insider_section(insider_tx_for_parser, filing_text, short_interest or {}, row.get('float_shares'), raw_bars, issuer_cusip, shares_outstanding))
    _cmember_dates = row.get('_cluster_member_dates') or {}
    if _cmember_dates and sec_cik and sec_submissions:
        _mem_om: list[Optional[bool]] = []
        _mem_not_10b5: list[Optional[bool]] = []
        for _mname, _mtx_date in _cmember_dates.items():
            _murl = _latest_form4_url_from_submissions(sec_cik, sec_submissions or {}, _mtx_date, _mname)
            _mtext = _safe_call(sec_get_filing_text, _murl) if _murl else None
            if _mtext is None:
                _mem_om.append(None)
                _mem_not_10b5.append(None)
            else:
                _mtext_up = _mtext.upper()
                _mem_om.append(True if 'OPEN MARKET' in _mtext_up else False)
                _m_10b5_mentioned = '10B5-1' in _mtext_up or '10B5 1' in _mtext_up
                _mem_not_10b5.append(False if _m_10b5_mentioned else True)
        if any((r is False for r in _mem_om)):
            row['_cluster_open_market_best_available'] = False
        elif _mem_om and all((r is True for r in _mem_om)):
            row['_cluster_open_market_best_available'] = True
        else:
            row['_cluster_open_market_best_available'] = None
        if any((r is False for r in _mem_not_10b5)):
            row['_cluster_not_10b5_best_available'] = False
        elif _mem_not_10b5 and all((r is True for r in _mem_not_10b5)):
            row['_cluster_not_10b5_best_available'] = True
        else:
            row['_cluster_not_10b5_best_available'] = None
    anchor_date = row.get('latest_insider_filing_date') if row.get('signal_age_days') is not None and int(row.get('signal_age_days')) <= 60 else (row.get('price_as_of') or date.today().isoformat())
    row['_underperf_reference_date'] = anchor_date
    row['_stock_ret_24m_anchor'] = _compute_trailing_return_from_bars_anchored(raw_bars, 504, anchor_date)
    row['_sector_etf_ret_24m_anchor'] = _compute_trailing_return_from_bars_anchored(sector_raw_bars, 504, anchor_date) if sector_etf_ticker else None
    row['_russell2000_return_12_1_skip_month'] = _compute_12_1_skip_month_exact(russell_raw_bars) if russell_raw_bars else None
    row['buy_within_10d_earnings_flag'] = None
    operative_buy_date = _buy_date_from_insider_row(confirmed_row) if confirmed_row is not None else None
    if operative_buy_date and row.get('last_earnings_date'):
        _diff = _exact_abs_trading_days_diff_from_bars(raw_bars, row.get('last_earnings_date'), operative_buy_date)
        if _diff is not None:
            row['buy_within_10d_earnings_flag'] = _diff <= 10
    def _ttm_open_market_buy_value(_rows: list[dict[str, Any]]) -> Optional[float]:
        total = 0.0
        found = False
        cutoff = date.today() - timedelta(days=365)
        for _ir in _rows:
            _code = str(_latest_non_null([_ir.get('transactionCode'), _ir.get('transactionType')]) or '').upper()
            if _code not in {'P', 'BUY'}:
                continue
            _d = _parse_iso_date(_latest_non_null([_ir.get('transactionDate'), _ir.get('filingDate')]))
            if _d is None:
                continue
            try:
                if datetime.strptime(_d, '%Y-%m-%d').date() < cutoff:
                    continue
            except Exception:
                continue
            _v = _to_float(_latest_non_null([_ir.get('value'), _ir.get('transactionValue')]))
            if _v is not None:
                total += _v
                found = True
        return total if found else None
    def _inc_stmt_sort_key(_row: dict[str, Any]) -> str:
        return str(_latest_non_null([_row.get('date'), _row.get('fillingDate'), _row.get('acceptedDate')]) or '0000-00-00')
    _sorted_inc_q = sorted((inc_q or []), key=_inc_stmt_sort_key, reverse=True)
    _shares_cur = _to_float((_sorted_inc_q or [{}])[0].get('weightedAverageShsOut')) if len(_sorted_inc_q or []) >= 1 else None
    _shares_prior = _to_float((_sorted_inc_q or [{}])[4].get('weightedAverageShsOut')) if len(_sorted_inc_q or []) >= 5 else None
    _dilution_dollar = None
    if _shares_cur is not None and _shares_prior is not None and row.get('current_price') not in (None, 0) and _shares_cur > _shares_prior:
        _dilution_dollar = (float(_shares_cur) - float(_shares_prior)) * float(row['current_price'])
    _ttm_buy_value = _ttm_open_market_buy_value(_raw_insider_data)
    row['ttm_insider_buy_vs_dilution'] = None if _dilution_dollar in (None, 0) or _ttm_buy_value is None else float(_ttm_buy_value) / float(_dilution_dollar)
    _merge_row(row, parse_sec_filing_section(sec_cik, sec_submissions or {}, row.get('_latest_buy_date')))
    _merge_row(row, parse_manual_review_section(identity, row, row, row))
    # Audit section deliberately omitted here — null_fields must be computed on the final
    # fully-merged row in score_and_finalize_rows(), not on the partial collection row.
    return row

