    chs_pass = _classify_chs_result(chs)
    piot_band = _piotroski_band_for_solvency(piotroski, market_cap)
    alt_band = _altman_band_for_solvency(altman, altman_variant)

    def _chs_only_raw_from_piot() -> Optional[float]:
        if piotroski is None:
            return None
        p = float(piotroski)
        if sector_class in {'financial', 'reit'}:
            if p >= 7.0:
                return 8.0
            if 4.0 <= p <= 6.0:
                # Component-level Piotroski data is unavailable in the current pipeline.
                # Updated v6.8 allows conservative reduction when breakdown is unavailable.
                return 5.0
            if p <= 3.0:
                # Preserve current conservative REIT/financial handling.
                return 8.0
            return None
        if p >= 7.0:
            return 8.0
        if 5.0 <= p <= 6.0:
            return 5.0
        if p == 4.0:
            return 2.0
        return None

    if market_cap_tier == 'Large':
        if chs_only_sector:
            if chs_pass is False:
                return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
            raw = _chs_only_raw_from_piot()
        else:
            if chs_pass is False:
                return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
            if alt_band is None and piot_band is None:
                return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
            if alt_band is not None and piot_band is not None:
                raw = min(alt_band, piot_band)
            elif alt_band is not None:
                raw = alt_band
            else:
                raw = piot_band
    elif market_cap_tier == 'Mid':
        if chs_pass is False:
            return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
        if chs_only_sector:
            raw = _chs_only_raw_from_piot()
        else:
            if alt_band is None and piot_band is None:
                return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
            if alt_band is not None and piot_band is not None:
                raw = min(alt_band, piot_band)
            elif alt_band is not None:
                raw = alt_band
            else:
                raw = piot_band
    elif market_cap_tier == 'Small':
        if chs_only_sector:
            if chs_pass is False:
                return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
            raw = _chs_only_raw_from_piot()
        else:
            if alt_band is None and piot_band is None:
                return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
            if alt_band is not None and piot_band is not None:
                raw = min(alt_band, piot_band)
            elif alt_band is not None:
                raw = alt_band
            else:
                raw = piot_band
    else:
        if chs_only_sector:
            raw = _chs_only_raw_from_piot() if chs_pass is True else None
        else:
            if alt_band is not None and piot_band is not None:
                raw = min(alt_band, piot_band)
            elif alt_band is not None:
                raw = alt_band
            else:
                raw = piot_band
    if raw is None:
        return _factor_result(None, None, 0.05, 'f7_solvency', 'f7_weighted')
    if adr_flag is True and raw > 8 and (piotroski is None or float(piotroski) < 8):
        raw = 8.0
    adjusted = raw
    if sector_class in {'financial', 'reit'} and piotroski is not None and 4.0 <= float(piotroski) <= 6.0:
        _append_manual_note(row, 'financial_reit_piot46_conservative_no_component_data')
    if days_to_cover is not None and 7.0 <= float(days_to_cover) <= 15.0:
        if str(row.get('dtc_independence_check')).strip().lower() != 'waived':
            adjusted -= 1.0
    if sector_class in {'financial', 'reit'} and piotroski is not None and float(piotroski) <= 3.0:
        adjusted = min(adjusted, 5.0)
    adjusted = _clamp_score(adjusted)
    return _factor_result(raw, adjusted, 0.05, 'f7_solvency', 'f7_weighted')

