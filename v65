        return _to_float(cached.get('total_call_volume'))
    if not MASSIVE_API_KEY or 'YOUR_' in MASSIVE_API_KEY:
        return None
    try:
        contracts = massive_list_option_contracts(underlying, day)
    except Exception:
        return None
    if not contracts:
        _write_json_file(cache_path, {'total_call_volume': None})
        return None
    total = 0.0
    seen = 0
    for c in contracts:
        ot = c.get('ticker') if isinstance(c, dict) else None
        if not ot:
            continue
        try:
            agg = massive_get_option_day_agg(ot, day)
        except Exception:
            return None
        results = agg.get('results') if isinstance(agg, dict) else None
        if isinstance(results, list) and results:
            total += float(_latest_non_null([results[0].get('v'), results[0].get('volume')]) or 0.0)
            seen += 1
    if seen == 0:
        _write_json_file(cache_path, {'total_call_volume': None})
        return None
    _write_json_file(cache_path, {'total_call_volume': total})
    return total

def _last_n_trading_dates_from_bars(bars: list[dict[str, Any]], anchor_date: Optional[str], n: int, include_anchor: bool=True) -> list[str]:
    if not bars or anchor_date is None or n <= 0:
        return []
    dates = sorted(set(d for d in [(_extract_bar_date(b) if '_extract_bar_date' in globals() else None) for b in bars] if d is not None and d <= anchor_date))
    if not include_anchor and dates and dates[-1] == anchor_date:
        dates = dates[:-1]
    return dates[-n:]

def _compute_options_flow_flag(underlying: str, signal_date: Optional[str], stock_bars: list[dict[str, Any]]) -> Optional[bool]:
    if not underlying or signal_date is None:
        return None
    same_day_total = _total_call_volume_for_underlying_day(underlying, signal_date)
    if same_day_total is None:
        return None
    baseline_days = _last_n_trading_dates_from_bars(stock_bars, signal_date, 30, include_anchor=False)
    if len(baseline_days) < 30:
        return None
    baseline_totals = []
    for d in baseline_days:
        v = _total_call_volume_for_underlying_day(underlying, d)
        if v is None:
            return None
        baseline_totals.append(float(v))
    baseline_avg = statistics.mean(baseline_totals) if baseline_totals else None
    if baseline_avg in (None, 0):
        return None
    return float(same_day_total) > 2.0 * float(baseline_avg)

