    options_flow = row.get('options_flow_flag')
    si_trending_down = row.get('si_trending_down_flag')
    si_trending_down_current = row.get('_si_trending_down_current')
    ttm_buy_vs_dilution = row.get('ttm_insider_buy_vs_dilution')
    sector_underperf = row.get('sector_underperformance_24m')
    ceo_cfo_drawdown = row.get('ceo_cfo_drawdown_buy_flag')
    market_cap_tier = row.get('market_cap_tier')
    cluster_includes_ceo_cfo = row.get('_cluster_includes_ceo_cfo')
    cluster_director_only = row.get('_cluster_director_only')
    roic_top_quartile = row.get('_roic_top_quartile')
    institutional_adj = row.get('_institutional_convergence_adjustment')
    confirmed_catalyst = row.get('_confirmed_catalyst_flag')
    is_swing_trade = row.get('_is_swing_trade')
    raw = None
    is_ceo_cfo = _role_is_ceo_cfo(title)
    is_director = _role_is_director(title)
    director_threshold = _factor5_director_fallback_threshold(market_cap_tier)
    cluster_confirmed = cluster_flag is True and cluster_open_market_best_available is True
    if cluster_confirmed and cluster_count is not None and (int(cluster_count) >= 3) and (cluster_includes_ceo_cfo is True) and (cluster_not_10b5_best_available is True):
        raw = 10.0
    elif cluster_confirmed and cluster_count is not None and (int(cluster_count) >= 2) and (cluster_includes_ceo_cfo is True):
        raw = 9.0
    elif ceo_cfo_drawdown is True and open_market is True and (roic_top_quartile is True) and (holdings_pct is not None) and (float(holdings_pct) >= 1.0):
        raw = 9.0
    elif cluster_confirmed and cluster_count is not None and (int(cluster_count) >= 2) and (cluster_director_only is True):
        raw = 7.0
    elif is_ceo_cfo and open_market is True and (holdings_pct is not None) and (float(holdings_pct) >= 1.0) and (signal_age_days is not None) and (int(signal_age_days) <= 120):
        raw = 6.0
    elif is_ceo_cfo and market_cap_tier == 'Small' and (open_market is True) and (latest_value is not None) and (float(latest_value) >= 100000) and (signal_age_days is not None) and (int(signal_age_days) <= 120):
        raw = 5.0
    elif is_director and open_market is True and (holdings_pct is not None) and (float(holdings_pct) >= 1.0) and (signal_age_days is not None) and (int(signal_age_days) <= 120):
        raw = 4.0
    elif is_director and open_market is True and (holdings_verified is False) and (fallback_used is True) and (signal_age_days is not None) and (int(signal_age_days) <= 120) and (director_threshold is not None) and (latest_value is not None) and (float(latest_value) >= float(director_threshold)):
        raw = 3.0
    else:
        raw = 0.0
    adjusted = raw
    if signal_age_days is not None:
        if int(signal_age_days) > 240:
            return _factor_result(raw, 0.0, 0.15, 'f5_insider', 'f5_weighted')
        elif 120 <= int(signal_age_days) <= 240:
            adjusted -= 2.0
    if tenb5_regime == 'post_reform_confirmed':
        adjusted -= 1.0
    if holdings_verified is False and fallback_used is True:
        adjusted -= 1.0
    low_float_mechanical = market_cap_tier == 'Small' and filing_short_pct is not None and float(filing_short_pct) > 20.0 and row.get('_si_pct_outstanding_at_filing') is not None and float(row['_si_pct_outstanding_at_filing']) <= 20.0
    if filing_short_pct is not None and float(filing_short_pct) > 20.0:
        if market_cap_tier == 'Small' and (low_float_mechanical or (isinstance(dtc_check, str) and (dtc_check.strip().lower() == 'waived'))):
            adjusted -= 1.0
        else:
            adjusted -= 2.0
    if buy_within_earnings is True:
        adjusted -= 1.0
    if institutional_adj is not None:
        adjusted += float(institutional_adj)
    if options_flow is True:
        adjusted += 0.5
    if _bool(is_swing_trade) and current_short_pct is not None and (float(current_short_pct) > 10.0) and (confirmed_catalyst is True) and (si_trending_down_current is True):
        adjusted += 1.0
    elif si_trending_down_current is True and current_short_pct is not None and float(current_short_pct) <= 10.0:
        adjusted += 0.5
    if ttm_buy_vs_dilution is not None and float(ttm_buy_vs_dilution) < 0.1 and (row.get('net_dilution_pct') is not None) and (float(row['net_dilution_pct']) > 3.0):
        adjusted -= 2.0
    if analyst_count is not None and int(analyst_count) < 3 and cluster_confirmed and (cluster_includes_ceo_cfo is True):
        adjusted += 0.5
    adjusted = _clamp_score(adjusted)
    if sector_underperf is not None and float(sector_underperf) <= -15.0:
        adjusted -= 3.0
        if raw > 0:
            adjusted = max(adjusted, 1.0)
    if tenb5_regime == 'pre_reform_or_unverifiable':
        adjusted -= 3.0
        adjusted = min(adjusted, 4.0)
    return _factor_result(raw, _clamp_score(adjusted), 0.15, 'f5_insider', 'f5_weighted')
def _apply_composite_core(row: dict[str, Any]) -> dict[str, Any]:
    out = _none_dict(['raw_composite', 'standalone_deduction_vol', 'standalone_deduction_si_dtc', 'standalone_deduction_eq', 'standalone_deduction_concentration', 'standalone_deduction_rates', 'total_standalone_deductions', 'regime_deduction_soft_crash', 'regime_deduction_full_crash', 'regime_deduction_mtum_vtv', 'regime_deduction_hy_oas', 'total_regime_deductions', 'final_composite', 'momentum_dependent_entry_flag', 'zeroed_momentum_composite', 'override_1_holdings', 'override_2_mtum_vtv', 'override_3_soft_crash_insider', 'override_4a_full_crash', 'override_4b_soft_crash_price', 'override_5_below_200sma', 'mid_tier_cap_applied', 'small_tier_cap_applied', 'final_tier', 'tier_floor_pct', 'tier_range_pct', 'composite_minus_floor', 'tier_score_range', 'composite_proportional_size', 'atr_stop_implied_pct', 'atr_adjusted_size', 'final_position_size_pct'])
    weighted_values = [row.get('f1_weighted'), row.get('f2_weighted'), row.get('f3_weighted'), row.get('f4_weighted'), row.get('f5_weighted'), row.get('f6_weighted'), row.get('f7_weighted')]
    if any(v is None for v in weighted_values):
        return out
    out['raw_composite'] = sum(float(v) for v in weighted_values) * 10.0
    hv30 = row.get('hv30_annualized')
    mtum_gt_5 = row.get('_mtum_outperforms_vtv_gt_5pp')
    out['standalone_deduction_vol'] = 0.0 if hv30 is None or mtum_gt_5 is True else STANDALONE_VOL_DEDUCTION if float(hv30) > 40.0 else 0.0
    current_short_pct = row.get('short_interest_pct_float')
    dtc = row.get('days_to_cover')
    out['standalone_deduction_si_dtc'] = STANDALONE_SI_DTC_DEDUCTION if current_short_pct is not None and dtc is not None and 5.0 <= float(current_short_pct) <= 15.0 and 3.0 <= float(dtc) <= 7.0 else 0.0
    eq_score = row.get('stacking_eq_cumulative_score')
    out['standalone_deduction_eq'] = STANDALONE_EQ_DEDUCTION if eq_score is not None and float(eq_score) <= -2.0 else 0.0
    sector_theme_pct = row.get('_sector_theme_portfolio_pct')
    out['standalone_deduction_concentration'] = STANDALONE_CONCENTRATION_DEDUCTION if sector_theme_pct is not None and 20.0 <= float(sector_theme_pct) <= 25.0 else 0.0
    treasury_change = row.get('treasury_10y_30d_change_bps')
    peg = row.get('peg_ratio')
    ps = row.get('price_to_sales')
    rates_trigger = treasury_change is not None and float(treasury_change) > 50.0 and ((ps is not None and float(ps) > 10.0) or (peg is not None and float(peg) > 2.5))
    out['standalone_deduction_rates'] = STANDALONE_RATES_DEDUCTION if rates_trigger else 0.0
    out['total_standalone_deductions'] = sum(float(out[k]) for k in ['standalone_deduction_vol', 'standalone_deduction_si_dtc', 'standalone_deduction_eq', 'standalone_deduction_concentration', 'standalone_deduction_rates'])
    out['regime_deduction_soft_crash'] = REGIME_SOFT_CRASH_DEDUCTION if row.get('soft_crash_flag_active') is True else 0.0
    out['regime_deduction_full_crash'] = REGIME_FULL_CRASH_DEDUCTION if row.get('full_crash_flag_active') is True else 0.0
    out['regime_deduction_mtum_vtv'] = REGIME_MTUM_VTV_DEDUCTION if row.get('mtum_vtv_cap_active') is True else 0.0
    out['regime_deduction_hy_oas'] = REGIME_HY_OAS_MOMENTUM_DEDUCTION if row.get('hy_oas_bear_rally_active') is True else 0.0
    out['total_regime_deductions'] = sum(float(out[k]) for k in ['regime_deduction_soft_crash', 'regime_deduction_full_crash', 'regime_deduction_mtum_vtv', 'regime_deduction_hy_oas'])
    out['final_composite'] = float(out['raw_composite']) + float(out['total_standalone_deductions']) + float(out['total_regime_deductions'])
    base_tier = _tier_from_composite(out['final_composite'])
    f1_weighted = row.get('f1_weighted')
    out['zeroed_momentum_composite'] = None if f1_weighted is None else float(out['final_composite']) - float(f1_weighted) * 10.0
    tier_floor_score = _tier_floor_score(base_tier)
    out['momentum_dependent_entry_flag'] = bool(base_tier in {'A', 'B', 'C'} and out['zeroed_momentum_composite'] is not None and tier_floor_score is not None and float(out['zeroed_momentum_composite']) < float(tier_floor_score))
    out['override_1_holdings'] = row.get('insider_holdings_verified') is False and row.get('insider_fallback_threshold_used') is True
    out['override_2_mtum_vtv'] = row.get('mtum_vtv_cap_active') is True and out['momentum_dependent_entry_flag'] is True and out['final_composite'] is not None and float(out['final_composite']) > OVERRIDE_2_CAP_SCORE
    if out['override_2_mtum_vtv']:
        out['final_composite'] = OVERRIDE_2_CAP_SCORE
    final_tier = _tier_from_composite(out['final_composite'])
    out['override_3_soft_crash_insider'] = row.get('soft_crash_flag_active') is True and row.get('f5_insider_raw') is not None and float(row.get('f5_insider_raw')) < 7.0
    within_5 = _within_pct_of_52w_high(row.get('current_price'), row.get('high_52w'), 5.0)
    within_10 = _within_pct_of_52w_high(row.get('current_price'), row.get('high_52w'), 10.0)
    top10 = row.get('_top_10pct_sector_momentum')
    top20 = row.get('_top_20pct_sector_momentum')
    out['override_4a_full_crash'] = row.get('full_crash_flag_active') is True and (within_5 is not True) and (top10 is False)
    out['override_4b_soft_crash_price'] = row.get('soft_crash_flag_active') is True and (within_10 is not True) and (top20 is False)
    out['override_5_below_200sma'] = row.get('pct_vs_200sma') is not None and float(row.get('pct_vs_200sma')) < 0 and final_tier in {'A', 'B'}
    if out['override_4a_full_crash']:
        final_tier = 'Eliminate'
    else:
        if out['override_1_holdings'] or out['override_3_soft_crash_insider'] or out['override_4b_soft_crash_price'] or out['override_5_below_200sma']:
            final_tier = _cap_tier_to_c_if_above(final_tier)
    out['mid_tier_cap_applied'] = row.get('market_cap_tier') == 'Mid' and final_tier in {'A', 'B'}
    if out['mid_tier_cap_applied']:
        final_tier = 'C'
    out['small_tier_cap_applied'] = row.get('market_cap_tier') == 'Small'
    out['final_tier'] = final_tier
    out['tier_floor_pct'] = _tier_floor_pct(final_tier)
    out['tier_range_pct'] = _tier_range_pct(final_tier)
    out['tier_score_range'] = _tier_score_range(final_tier)
    score_floor = _tier_floor_score(final_tier)
    out['composite_minus_floor'] = None if out['final_composite'] is None or score_floor is None else float(out['final_composite']) - float(score_floor)
    if final_tier in {'A', 'B', 'C'} and out['final_composite'] is not None and score_floor is not None and out['tier_floor_pct'] is not None and out['tier_range_pct'] is not None and out['tier_score_range'] not in (None, 0):
        size = float(out['tier_floor_pct']) + float(out['tier_range_pct']) * ((float(out['final_composite']) - float(score_floor)) / float(out['tier_score_range']))
        abs_cap = _tier_abs_cap(final_tier)
        if abs_cap is not None:
            size = min(size, float(abs_cap))
        if row.get('market_cap_tier') == 'Small':
            size = min(size, SMALL_TIER_HARD_CAP)
        out['composite_proportional_size'] = max(0.0, size)
    else:
        out['composite_proportional_size'] = None
    atr_20d = row.get('atr_20d')
    current_price = row.get('current_price')
    max_stop_pct = _max_stop_pct_from_trade_type(row.get('_trade_type'))
    if atr_20d is not None and current_price not in (None, 0):
        out['atr_stop_implied_pct'] = float(atr_20d) * 2.5 / float(current_price) * 100.0
    if out['composite_proportional_size'] is not None:
        if out['atr_stop_implied_pct'] is not None and max_stop_pct is not None and float(out['atr_stop_implied_pct']) > float(max_stop_pct):
            out['atr_adjusted_size'] = float(out['composite_proportional_size']) * (float(max_stop_pct) / float(out['atr_stop_implied_pct']))
        else:
            out['atr_adjusted_size'] = float(out['composite_proportional_size'])
        out['final_position_size_pct'] = out['atr_adjusted_size']
        if row.get('market_cap_tier') == 'Small' and out['final_position_size_pct'] is not None:
            out['final_position_size_pct'] = min(float(out['final_position_size_pct']), SMALL_TIER_HARD_CAP)
    return out


def apply_composite(row: dict[str, Any]) -> dict[str, Any]:
    out = _apply_composite_core(row)
    if TOTAL_PORTFOLIO_CAPITAL is not None and out.get('final_position_size_pct') is not None and (row.get('adtv_20d_dollar') not in (None, 0)):
        intended_position_dollar = float(TOTAL_PORTFOLIO_CAPITAL) * (float(out['final_position_size_pct']) / 100.0)
        row['position_to_adtv_pct'] = intended_position_dollar / float(row['adtv_20d_dollar']) * 100.0
    return out


def _append_manual_note(row: dict[str, Any], note: str) -> None:
    notes = [] if row.get('manual_review_notes') in (None, '') else str(row.get('manual_review_notes')).split('|')
    if note not in notes:
        notes.append(note)
    row['manual_review_notes'] = '|'.join(notes) if notes else None


def _recompute_position_sizing_from_final_tier(row: dict[str, Any]) -> None:
    final_tier = row.get('final_tier')
    row['tier_floor_pct'] = _tier_floor_pct(final_tier)
    row['tier_range_pct'] = _tier_range_pct(final_tier)
    row['tier_score_range'] = _tier_score_range(final_tier)
    score_floor = _tier_floor_score(final_tier)
    final_composite = row.get('final_composite')
    row['composite_minus_floor'] = None if final_composite is None or score_floor is None else float(final_composite) - float(score_floor)
    if final_tier not in {'A', 'B', 'C'}:
        row['composite_proportional_size'] = 0.0 if final_tier == 'Eliminate' else None
        row['atr_adjusted_size'] = 0.0 if final_tier == 'Eliminate' else None
        row['final_position_size_pct'] = 0.0 if final_tier == 'Eliminate' else None
        return
    if final_composite is None or score_floor is None or row.get('tier_floor_pct') is None or row.get('tier_range_pct') is None or row.get('tier_score_range') in (None, 0):
        row['composite_proportional_size'] = None
        row['atr_adjusted_size'] = None
        row['final_position_size_pct'] = None
        return
    size = float(row['tier_floor_pct']) + float(row['tier_range_pct']) * ((float(final_composite) - float(score_floor)) / float(row['tier_score_range']))
    abs_cap = _tier_abs_cap(final_tier)
    if abs_cap is not None:
        size = min(size, float(abs_cap))
    if row.get('market_cap_tier') == 'Small':
        size = min(size, SMALL_TIER_HARD_CAP)
    row['composite_proportional_size'] = max(0.0, size)
    atr_stop_implied_pct = row.get('atr_stop_implied_pct')
    max_stop_pct = _max_stop_pct_from_trade_type(row.get('_trade_type'))
    if atr_stop_implied_pct is not None and max_stop_pct is not None and float(atr_stop_implied_pct) > float(max_stop_pct):
        row['atr_adjusted_size'] = float(row['composite_proportional_size']) * (float(max_stop_pct) / float(atr_stop_implied_pct))
    else:
        row['atr_adjusted_size'] = float(row['composite_proportional_size'])
    row['final_position_size_pct'] = row['atr_adjusted_size']
    if row.get('market_cap_tier') == 'Small' and row['final_position_size_pct'] is not None:
        row['final_position_size_pct'] = min(float(row['final_position_size_pct']), SMALL_TIER_HARD_CAP)
    if TOTAL_PORTFOLIO_CAPITAL is not None and row.get('final_position_size_pct') is not None and row.get('adtv_20d_dollar') not in (None, 0):
        intended_position_dollar = float(TOTAL_PORTFOLIO_CAPITAL) * (float(row['final_position_size_pct']) / 100.0)
        row['position_to_adtv_pct'] = intended_position_dollar / float(row['adtv_20d_dollar']) * 100.0
    elif row.get('final_position_size_pct') == 0.0:
        row['position_to_adtv_pct'] = 0.0


def _eliminate_via_portfolio_guard(row: dict[str, Any], note: str) -> None:
    row['final_tier'] = 'Eliminate'
    _append_manual_note(row, note)
    _recompute_position_sizing_from_final_tier(row)


def apply_entry_portfolio_guards(row: dict[str, Any]) -> None:
    row['manual_review_portfolio_context'] = False
    final_tier = row.get('final_tier')
    final_pos = row.get('final_position_size_pct')
    is_swing = _bool(row.get('_is_swing_trade'))
    market_cap_tier = row.get('market_cap_tier')
    required_context = [CURRENT_POSITION_COUNT, CURRENT_SECTOR_THEME_PORTFOLIO_PCT, CURRENT_CASH_PCT]
    if final_tier == 'A':
        required_context.append(CURRENT_TIER_A_COUNT)
    if market_cap_tier == 'Small':
        required_context.extend([CURRENT_SMALL_TIER_COUNT, CURRENT_SMALL_TIER_ALLOCATION_PCT, CURRENT_SMALL_PLUS_MID_ALLOCATION_PCT])
    elif market_cap_tier == 'Mid':
        required_context.extend([CURRENT_MID_TIER_COUNT, CURRENT_SMALL_PLUS_MID_ALLOCATION_PCT])
    if row.get('adr_flag') is True:
        required_context.append(CURRENT_ADR_ALLOCATION_PCT)
    if row.get('chinese_adr_flag') is True:
        required_context.append(CURRENT_CHINESE_ADR_ALLOCATION_PCT)
    if is_swing:
        required_context.extend([CURRENT_SWING_POSITION_COUNT, CURRENT_SWING_ALLOCATION_PCT])
    if final_tier in {'A', 'B', 'C'} and row.get('gics_4digit') not in (None, '') and CURRENT_GICS_4DIGIT_POSITION_COUNTS is None:
        required_context.append(None)
    if any(v is None for v in required_context):
        row['manual_review_portfolio_context'] = True
        _append_manual_note(row, 'portfolio_context_incomplete')
    if final_tier in {'A', 'B', 'C'} and CURRENT_POSITION_COUNT is not None and int(CURRENT_POSITION_COUNT) >= 15:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_max_positions')
        return
    if is_swing and row.get('f5_insider_raw') is not None and float(row.get('f5_insider_raw')) <= 0.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_requires_insider_signal')
        return
    if is_swing and row.get('_confirmed_catalyst_flag') is not True:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_requires_confirmed_catalyst')
        return
    if is_swing and row.get('f1_momentum_adjusted') is not None and float(row.get('f1_momentum_adjusted')) < 6.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_requires_momentum_6')
        return
    if is_swing and row.get('final_tier') == 'A':
        row['final_tier'] = 'B'
        _append_manual_note(row, 'portfolio_guard_swing_cap_to_B')
        _recompute_position_sizing_from_final_tier(row)
    final_tier = row.get('final_tier')
    final_pos = row.get('final_position_size_pct')
    if final_tier == 'A' and CURRENT_TIER_A_COUNT is not None and int(CURRENT_TIER_A_COUNT) >= 3:
        row['final_tier'] = 'B'
        _append_manual_note(row, 'portfolio_guard_tier_a_cap_to_B')
        _recompute_position_sizing_from_final_tier(row)
        final_tier = row.get('final_tier')
        final_pos = row.get('final_position_size_pct')
    if row.get('adr_flag') is True and row.get('dual_listing_flag') is not True and final_tier in {'A', 'B', 'C'} and final_pos is not None and float(final_pos) > 3.0:
        prior_final_pos = float(final_pos)
        row['final_position_size_pct'] = 3.0
        final_pos = 3.0
        _append_manual_note(row, 'portfolio_guard_non_dual_listed_adr_capped_to_3pct')
        pos_to_adtv_existing = row.get('position_to_adtv_pct')
        if pos_to_adtv_existing is not None and prior_final_pos > 0:
            row['position_to_adtv_pct'] = float(pos_to_adtv_existing) * (float(final_pos) / float(prior_final_pos))
        elif TOTAL_PORTFOLIO_CAPITAL is not None and row.get('adtv_20d_dollar') not in (None, 0):
            intended_position_dollar = float(TOTAL_PORTFOLIO_CAPITAL) * (float(final_pos) / 100.0)
            row['position_to_adtv_pct'] = intended_position_dollar / float(row['adtv_20d_dollar']) * 100.0
    if final_tier in {'A', 'B', 'C'} and final_pos is not None and CURRENT_SECTOR_THEME_PORTFOLIO_PCT is not None and (float(CURRENT_SECTOR_THEME_PORTFOLIO_PCT) + float(final_pos)) > 25.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_sector_theme_limit')
        return
    if market_cap_tier == 'Small' and final_tier in {'A', 'B', 'C'} and CURRENT_SMALL_TIER_COUNT is not None and int(CURRENT_SMALL_TIER_COUNT) >= 3:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_small_tier_count_limit')
        return
    if market_cap_tier == 'Mid' and final_tier in {'A', 'B', 'C'} and CURRENT_MID_TIER_COUNT is not None and int(CURRENT_MID_TIER_COUNT) >= 4:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_mid_tier_count_limit')
        return
    if market_cap_tier in {'Small', 'Mid'} and final_tier in {'A', 'B', 'C'} and final_pos is not None and CURRENT_SMALL_PLUS_MID_ALLOCATION_PCT is not None and (float(CURRENT_SMALL_PLUS_MID_ALLOCATION_PCT) + float(final_pos)) > 10.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_small_mid_allocation_limit')
        return
    if market_cap_tier == 'Small' and final_tier in {'A', 'B', 'C'} and final_pos is not None:
        if CURRENT_SMALL_TIER_ALLOCATION_PCT is None:
            row['manual_review_portfolio_context'] = True
            _append_manual_note(row, 'portfolio_guard_small_tier_allocation_context_missing')
        elif (float(CURRENT_SMALL_TIER_ALLOCATION_PCT) + float(final_pos)) > 3.0:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_small_tier_allocation_limit')
            return
    if is_swing and final_tier in {'A', 'B', 'C'}:
        next_earnings_date = row.get('_next_earnings_date')
        if next_earnings_date is None:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_earnings_date_unconfirmed')
            return
        try:
            next_dt = datetime.strptime(str(next_earnings_date), '%Y-%m-%d').date()
        except Exception:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_earnings_date_unconfirmed')
            return
        if (next_dt - date.today()).days <= 15:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_pre_earnings_window')
            return
    if final_tier in {'A', 'B', 'C'}:
        gics_4digit = row.get('gics_4digit')
        gics_position_count = None
        if gics_4digit in (None, ''):
            row['manual_review_portfolio_context'] = True
            _append_manual_note(row, 'portfolio_guard_missing_gics_4digit')
        elif isinstance(CURRENT_GICS_4DIGIT_POSITION_COUNTS, dict):
            try:
                gics_position_count = int(CURRENT_GICS_4DIGIT_POSITION_COUNTS.get(str(gics_4digit), 0))
            except Exception:
                gics_position_count = None
        if gics_4digit not in (None, '') and gics_position_count is None:
            row['manual_review_portfolio_context'] = True
            _append_manual_note(row, 'portfolio_guard_gics_4digit_context_missing')
        elif gics_position_count is not None and gics_position_count >= 3:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_gics_4digit_limit')
            return
    pos_to_adtv = row.get('position_to_adtv_pct')
    pos_to_adtv_limit = 5.0 if market_cap_tier in {'Large', 'Mid'} else 3.0 if market_cap_tier == 'Small' else None
    if final_tier in {'A', 'B', 'C'} and pos_to_adtv_limit is not None:
        if pos_to_adtv is None:
            row['manual_review_portfolio_context'] = True
            _append_manual_note(row, 'portfolio_guard_position_to_adtv_unavailable')
        elif float(pos_to_adtv) > pos_to_adtv_limit:
            row['manual_review_portfolio_context'] = True
            _append_manual_note(row, 'portfolio_guard_position_to_adtv_flag')
    if final_tier in {'A', 'B', 'C'} and row.get('_hy_oas_absolute_gt_600') is True:
        if row.get('return_12_1_skip_month') is None or float(row.get('return_12_1_skip_month')) <= 0.0:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_hy_oas_abs_600_requires_positive_12_1')
            return
        if _within_pct_of_52w_high(row.get('current_price'), row.get('high_52w'), 15.0) is not True:
            _eliminate_via_portfolio_guard(row, 'portfolio_guard_hy_oas_abs_600_requires_within_15pct_52w_high')
            return
    if is_swing and final_tier in {'A', 'B', 'C'} and CURRENT_SWING_POSITION_COUNT is not None and int(CURRENT_SWING_POSITION_COUNT) >= 5:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_count_limit')
        return
    if is_swing and final_tier in {'A', 'B', 'C'} and final_pos is not None and CURRENT_SWING_ALLOCATION_PCT is not None and (float(CURRENT_SWING_ALLOCATION_PCT) + float(final_pos)) > 30.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_swing_allocation_limit')
        return
    if row.get('adr_flag') is True and final_tier in {'A', 'B', 'C'} and final_pos is not None and CURRENT_ADR_ALLOCATION_PCT is not None and (float(CURRENT_ADR_ALLOCATION_PCT) + float(final_pos)) > 10.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_adr_allocation_limit')
        return
    if row.get('chinese_adr_flag') is True and final_tier in {'A', 'B', 'C'} and final_pos is not None and CURRENT_CHINESE_ADR_ALLOCATION_PCT is not None and (float(CURRENT_CHINESE_ADR_ALLOCATION_PCT) + float(final_pos)) > 5.0:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_chinese_adr_allocation_limit')
        return
    if row.get('_hy_oas_widening_gt_300') is True:
        required_cash_floor = 25.0
    elif CURRENT_NEUTRAL_REGIME_ACTIVE is True:
        required_cash_floor = 15.0
    else:
        required_cash_floor = 10.0
    if CURRENT_NEUTRAL_REGIME_ACTIVE is None:
        row['manual_review_regime_state'] = True
        _append_manual_note(row, 'neutral_regime_state_unavailable_cash_floor_default_10')
    if final_tier in {'A', 'B', 'C'} and final_pos is not None and CURRENT_CASH_PCT is not None and (float(CURRENT_CASH_PCT) - float(final_pos)) < required_cash_floor:
        _eliminate_via_portfolio_guard(row, 'portfolio_guard_cash_floor')
        return


def _apply_chs_cross_section(rows: list[dict[str, Any]], is_full_scored_universe: bool=False) -> None:
    if (not is_full_scored_universe) or len(rows) < 10:
        for row in rows:
            row['chs_result'] = None
        return
    vals = sorted([float(row['_chs_score_raw']) for row in rows if row.get('_chs_score_raw') is not None])
    if len(vals) < 10:
        for row in rows:
            row['chs_result'] = None
        return
    n_fail = max(int(math.ceil(len(vals) * 0.10)), 1)
    cutoff = vals[-n_fail]
    for row in rows:
        raw = row.get('_chs_score_raw')
        if raw is None:
            row['chs_result'] = None
        else:
            row['chs_result'] = 'fail' if float(raw) >= float(cutoff) else 'pass'

def score_and_finalize_rows(rows: list[dict[str, Any]]) -> list[dict[str, Any]]:
    _assert_peer_universe_loaded(CURRENT_PEER_UNIVERSE_ROWS, rows[0].get('run_mode') if rows else None)
    _apply_chs_cross_section(rows, is_full_scored_universe=bool(rows) and str(rows[0].get('run_mode') or '').strip().lower() not in {'smoke', 'subset'})
    for row in rows:
        if row.get('manual_review_chs_required') is True and row.get('chs_result') in {'pass', 'fail'}:
            row['manual_review_chs_required'] = False
    enrich_cross_section(rows, CURRENT_PEER_UNIVERSE_ROWS)
    for row in rows:
        hard_result, hard_reasons = apply_hard_floors(row)
        row['hard_floor_result'] = hard_result
        row['hard_floor_fail_reasons'] = '|'.join(hard_reasons)
        f1 = score_factor_1(row)
        _merge_row(row, f1)
        f2 = score_factor_2(row)
        _merge_row(row, {k: v for k, v in f2.items() if k in OUTPUT_COLUMNS})
        row['_stacking_eq_cumulative_score'] = f2.get('_stacking_eq_cumulative_score')
        row['stacking_eq_cumulative_score'] = f2.get('_stacking_eq_cumulative_score')
        f3 = score_factor_3(row)
        _merge_row(row, f3)
        f4 = score_factor_4(row)
        _merge_row(row, f4)
        f5 = score_factor_5(row)
        _merge_row(row, f5)
        f6 = score_factor_6(row)
        _merge_row(row, f6)
        f7 = score_factor_7(row)
        _merge_row(row, f7)
        stacking_result, stacking_fields = apply_stacking_rule(row)
        _merge_row(row, stacking_fields)
        row['stacking_result'] = stacking_result
        ccg_result, ccg_fields = apply_ccg(row)
        _merge_row(row, ccg_fields)
        row['ccg_result'] = ccg_result
        if hard_result == 'PASS' and stacking_result == 'PASS' and ccg_result == 'PASS':
            composite_fields = apply_composite(row)
            _merge_row(row, composite_fields)
            apply_entry_portfolio_guards(row)
        audit = parse_audit_section(row.get('run_id') or '', row.get('run_mode') or '', row.get('source_market_data') or 'alpaca_massive', row.get('source_quote') or 'alpaca_or_polygon', row.get('source_profile') or 'fmp_profile', row.get('source_cashflow') or 'fmp_cashflow', row.get('source_scores') or 'fmp_scores', row.get('source_analyst') or 'fmp_estimates_snapshot', row.get('source_insider') or 'finnhub_sec_polygon_options_soft_sec13f', row.get('source_sec') or 'sec_edgar_sec13f', row)
        _merge_row(row, audit)
    return rows

