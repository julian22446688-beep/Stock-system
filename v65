    try:
        payload = fred_get_series_observations(REGIME_HY_OAS_SERIES_ID)
        obs = payload.get('observations', []) if isinstance(payload, dict) else []
        vals: list[float] = []
        for o in obs[-120:]:
            try:
                vals.append(float(o.get('value')))
            except Exception:
                pass
        if len(vals) < 61:
            return {
                'widening_gt_150_bps': None,
