def _safe_filename(value: str) -> str:
    return re.sub(r'[^A-Za-z0-9._-]+', '_', str(value))

def _read_json_file(path: str) -> Any:
    if not os.path.exists(path):
        return None
    try:
        with open(path, 'r', encoding='utf-8') as f:
            return json.load(f)
    except Exception:
        return None

def _write_json_file(path: str, payload: Any) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + '.tmp'
    with open(tmp, 'w', encoding='utf-8') as f:
        json.dump(payload, f, indent=2, ensure_ascii=False)
    os.replace(tmp, path)

def _write_bytes_file(path: str, payload: bytes) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    tmp = path + '.tmp'
    with open(tmp, 'wb') as f:
        f.write(payload)
    os.replace(tmp, path)

def _extract_cusip_from_sources(profile_payload: Any, core_payload: Any, details_payload: Any) -> Optional[str]:
    candidates = []
    if isinstance(core_payload, dict):
        candidates.extend([core_payload.get('cusip'), core_payload.get('securityCusip')])
    elif isinstance(core_payload, list) and core_payload and isinstance(core_payload[0], dict):
        candidates.extend([core_payload[0].get('cusip'), core_payload[0].get('securityCusip')])
    if isinstance(profile_payload, list) and profile_payload and isinstance(profile_payload[0], dict):
        candidates.extend([profile_payload[0].get('cusip')])
    if isinstance(details_payload, dict):
        res = details_payload.get('results') if isinstance(details_payload.get('results'), dict) else details_payload
        if isinstance(res, dict):
            candidates.extend([res.get('cusip')])
    for c in candidates:
        if c is None:
            continue
        s = re.sub(r'[^A-Za-z0-9]', '', str(c).upper())
        if len(s) >= 8:
            return s[:9]
    return None

def _latest_reported_period_end_from_fmp_earnings_payloads(raw_fmp_earnings_surprises: Any, raw_fmp_earnings_report: Any) -> Optional[str]:
    fmp_earn = raw_fmp_earnings_surprises if isinstance(raw_fmp_earnings_surprises, list) else []
    fmp_report = raw_fmp_earnings_report if isinstance(raw_fmp_earnings_report, list) else []
    vals: list[str] = []

    def _period_end(r: dict) -> Optional[str]:
        return _parse_iso_date(_latest_non_null([
            r.get('calendarDate'),
            r.get('fiscalDateEnding'),
        ]))

    for _r in fmp_earn:
        _pd = _period_end(_r)
        if _pd is not None:
            vals.append(_pd)
    for _r in fmp_report:
        _pd = _period_end(_r)
        if _pd is not None:
            vals.append(_pd)
    return max(vals) if vals else None

def _future_estimate_rows_for_reported_period(est_rows: list[dict[str, Any]], reported_period_end: Optional[str]) -> list[dict[str, Any]]:
    if reported_period_end is None:
        return []
    rows = [r for r in est_rows if isinstance(r, dict) and (r.get('date') or r.get('fiscalDateEnding') or '') > reported_period_end]
    rows = sorted(rows, key=lambda r: str(r.get('date') or r.get('fiscalDateEnding') or '9999-12-31'))
    return rows

def _revision_snapshot_path(ticker: str) -> str:
    return os.path.join(REVISION_SNAPSHOT_DIR, f'{_safe_filename(ticker.upper())}.json')

def _load_revision_snapshots(ticker: str) -> list[dict[str, Any]]:
    data = _read_json_file(_revision_snapshot_path(ticker))
    return data if isinstance(data, list) else []

def _save_revision_snapshots(ticker: str, rows: list[dict[str, Any]]) -> None:
    _write_json_file(_revision_snapshot_path(ticker), rows[-200:])

def _record_revision_snapshot(ticker: str, est_rows: list[dict[str, Any]], reported_period_end: Optional[str], as_of: Optional[str]=None) -> None:
    if reported_period_end is None or not ticker:
        return
    future = _future_estimate_rows_for_reported_period(est_rows, reported_period_end)
    target = future[0] if future else None
    if not isinstance(target, dict):
        return
    eps_avg = _to_float(_latest_non_null([target.get('estimatedEpsAvg'), target.get('epsAvg'), target.get('epsEstimated')])) if '_to_float' in globals() else None
    fiscal_period = str(target.get('date') or target.get('fiscalDateEnding') or '').strip()
    if eps_avg is None or not fiscal_period:
        return
    rows = _load_revision_snapshots(ticker)
    snap = {'as_of': (_parse_iso_date(as_of) if '_parse_iso_date' in globals() else as_of) or date.today().isoformat(), 'fiscal_period_end': fiscal_period, 'estimated_eps_avg': eps_avg}
    rows = [r for r in rows if not (r.get('as_of') == snap['as_of'] and r.get('fiscal_period_end') == fiscal_period)]
    rows.append(snap)
    rows = sorted(rows, key=lambda r: str(r.get('as_of') or '0000-00-00'))
    _save_revision_snapshots(ticker, rows)

def _build_revision_source_from_fmp_analyst_estimates(est_rows: Any, ticker: Optional[str]=None, reported_period_end: Optional[str]=None, as_of: Optional[str]=None) -> Optional[dict[str, Any]]:
    t = str(ticker or '').strip().upper() if ticker else ''
    if not t or reported_period_end is None:
        return None
    est_list = est_rows if isinstance(est_rows, list) else []
    future = _future_estimate_rows_for_reported_period(est_list, reported_period_end)
    target = future[0] if future else None
    if not isinstance(target, dict):
        return {'revision_momentum_pct': None, 'revision_direction': 'skipped_no_90d_snapshot'}
    current_eps = _to_float(_latest_non_null([
        target.get('estimatedEpsAvg'),
        target.get('epsAvg'),
        target.get('epsEstimated'),
    ]))
    fiscal_period = str(target.get('date') or target.get('fiscalDateEnding') or '').strip()
    analyst_count = _to_int(_latest_non_null([
        target.get('numberAnalystsEstimatedRevenue'),
        target.get('numberAnalystEstimatedRevenue'),
        target.get('numberAnalystsEstimatedEps'),
        target.get('numberAnalystEstimatedEps'),
    ]))
    if analyst_count is None or analyst_count < 2:
        return {'revision_momentum_pct': None, 'revision_direction': 'skipped_insufficient_analysts'}
    if current_eps is None or not fiscal_period:
        return {'revision_momentum_pct': None, 'revision_direction': 'skipped_no_90d_snapshot'}
    as_of_str = _parse_iso_date(as_of) or date.today().isoformat()
    try:
        as_of_dt = datetime.strptime(as_of_str, '%Y-%m-%d').date()
    except Exception:
        as_of_dt = date.today()
        as_of_str = as_of_dt.isoformat()
    prior_candidates: list[tuple[int, int, dict[str, Any]]] = []
    for snap in _load_revision_snapshots(t):
        if not isinstance(snap, dict):
            continue
        if str(snap.get('fiscal_period_end') or '').strip() != fiscal_period:
            continue
        snap_as_of = _parse_iso_date(snap.get('as_of'))
        if snap_as_of is None or snap_as_of >= as_of_str:
            continue
        snap_eps = _to_float(snap.get('estimated_eps_avg'))
        if snap_eps is None or float(snap_eps) == 0.0:
            continue
        try:
            snap_dt = datetime.strptime(snap_as_of, '%Y-%m-%d').date()
        except Exception:
            continue
        delta_days = (as_of_dt - snap_dt).days
        if 75 <= delta_days <= 105:
            prior_candidates.append((abs(delta_days - 90), delta_days, snap))
    if not prior_candidates:
        return {'revision_momentum_pct': None, 'revision_direction': 'skipped_no_90d_snapshot'}
    _, _, prior_snap = sorted(prior_candidates, key=lambda x: (x[0], x[1]))[0]
    prior_eps = _to_float(prior_snap.get('estimated_eps_avg'))
    if prior_eps in (None, 0):
        return {'revision_momentum_pct': None, 'revision_direction': 'skipped_no_90d_snapshot'}
    revision_momentum_pct = ((float(current_eps) - float(prior_eps)) / abs(float(prior_eps))) * 100.0
    if revision_momentum_pct >= 5.0:
        revision_direction = 'up'
    elif revision_momentum_pct <= -5.0:
        revision_direction = 'down'
    else:
        revision_direction = 'flat_mixed'
    return {'revision_momentum_pct': revision_momentum_pct, 'revision_direction': revision_direction}

def _daily_log_returns_from_bars(bars: list[dict[str, Any]]) -> list[float]:
    vals: list[tuple[str, float]] = []
    for b in bars:
        d = _extract_bar_date(b) if '_extract_bar_date' in globals() else None
        c = _extract_close_from_bar(b) if '_extract_close_from_bar' in globals() else None
        if d is not None and c not in (None, 0):
            vals.append((d, float(c)))
    vals.sort(key=lambda x: x[0])
    out = []
    for i in range(1, len(vals)):
        prev = vals[i - 1][1]
        cur = vals[i][1]
        if prev not in (None, 0) and cur not in (None, 0):
            out.append(math.log(cur / prev))
    return out

def _monthly_log_returns_from_daily_bars(bars: list[dict[str, Any]], months: int=12) -> list[float]:
    month_to_last: dict[str, tuple[str, float]] = {}
    for b in bars:
        d = _extract_bar_date(b) if '_extract_bar_date' in globals() else None
        c = _extract_close_from_bar(b) if '_extract_close_from_bar' in globals() else None
        if d is None or c in (None, 0):
            continue
        key = d[:7]
        prev = month_to_last.get(key)
        if prev is None or d > prev[0]:
            month_to_last[key] = (d, float(c))
    months_sorted = sorted(month_to_last.keys())
    closes = [month_to_last[m][1] for m in months_sorted[-(months + 1):]]
    out = []
    for i in range(1, len(closes)):
        out.append(math.log(closes[i] / closes[i - 1]))
    return out

def _chs_decay_weighted_avg(vals: list[Optional[float]], phi: float=(2 ** (-1/3))) -> Optional[float]:
    seq = [float(v) for v in vals if v is not None]
    if not seq:
        return None
    weights = [phi ** i for i in range(len(seq))]
    weights = list(reversed(weights))
    denom = sum(weights)
    return None if denom == 0 else sum(v * w for v, w in zip(seq, weights)) / denom

def _compute_chs_raw_score(raw_fmp_balance_quarter: Any, raw_fmp_income_ttm: Any, market_cap: Optional[float], current_price: Optional[float], price_bars: list[dict[str, Any]], market_proxy_bars: list[dict[str, Any]]) -> Optional[float]:
    bal_q = raw_fmp_balance_quarter if isinstance(raw_fmp_balance_quarter, list) else []
    inc_q = raw_fmp_income_ttm if isinstance(raw_fmp_income_ttm, list) else []
    if not bal_q or market_cap is None:
        return None
    def _stmt_sort(r: dict) -> str:
        return str(_latest_non_null([r.get('date'), r.get('fillingDate'), r.get('acceptedDate')]) or '0000-00-00')
    bal_q = sorted(bal_q, key=_stmt_sort, reverse=True)
    inc_q = sorted(inc_q, key=_stmt_sort, reverse=True)
    b0 = bal_q[0] if bal_q else {}
    total_liabilities = _to_float(b0.get('totalLiabilities'))
    cash = _latest_non_null([_to_float(b0.get('cashAndCashEquivalents')), _to_float(b0.get('cashAndShortTermInvestments'))])
    book_equity = _to_float(_latest_non_null([b0.get('totalStockholdersEquity'), b0.get('totalEquity')]))
    market_assets = None if total_liabilities is None else float(total_liabilities) + float(market_cap)
    if market_assets in (None, 0):
        return None
    ni_quarters = []
    for r in inc_q[:4]:
        ni_quarters.append(_to_float(_latest_non_null([r.get('netIncome'), r.get('netIncomeApplicableToCommonShares')])) )
    nimta_vals = [None if ni is None else float(ni) / float(market_assets) for ni in ni_quarters]
    nimtaavg = _chs_decay_weighted_avg(nimta_vals)
    tlmta = None if total_liabilities is None else float(total_liabilities) / float(market_assets)
    cashmta = None if cash is None else float(cash) / float(market_assets)
    stock_monthly = _monthly_log_returns_from_daily_bars(price_bars, 12)
    market_monthly = _monthly_log_returns_from_daily_bars(market_proxy_bars, 12)
    exretavg = None
    if stock_monthly and len(stock_monthly) == len(market_monthly):
        exretavg = _chs_decay_weighted_avg([s - m for s, m in zip(stock_monthly, market_monthly)])
    daily = _daily_log_returns_from_bars(price_bars[-63:])
    sigma = statistics.pstdev(daily) * math.sqrt(252.0) if len(daily) >= 5 else None
    rsize = math.log(max(float(market_cap), 1.0) / US_TOTAL_MARKET_CAP_PROXY)
    mb = None if book_equity in (None, 0) else float(market_cap) / float(book_equity)
    price_term = None if current_price in (None, 0) else math.log(min(float(current_price), 15.0))
    vals = [nimtaavg, tlmta, exretavg, sigma, rsize, cashmta, mb, price_term]
    if any(v is None for v in vals):
        return None
    return (-20.26 * float(nimtaavg) + 1.42 * float(tlmta) - 7.13 * float(exretavg) + 1.41 * float(sigma) - 0.045 * float(rsize) - 2.13 * float(cashmta) + 0.075 * float(mb) - 0.058 * float(price_term) - 9.16)

def _short_interest_rows(raw_massive_short_interest: Any) -> list[dict[str, Any]]:
    rows = _get_nested(raw_massive_short_interest, 'results') if '_get_nested' in globals() else None
    if isinstance(rows, dict):
        rows = [rows]
    rows = rows if isinstance(rows, list) else []
    return sorted(rows, key=lambda r: str(_latest_non_null([r.get('settlement_date'), r.get('settlementDate'), r.get('date')]) or '0000-00-00'), reverse=True)

def _si_row_date(r: Optional[dict[str, Any]]) -> Optional[str]:
    if not isinstance(r, dict):
        return None
    return _parse_iso_date(_latest_non_null([r.get('settlement_date'), r.get('settlementDate'), r.get('date')])) if '_parse_iso_date' in globals() else None

def _si_row_shares(r: Optional[dict[str, Any]]) -> Optional[float]:
    if not isinstance(r, dict):
        return None
    return _to_float(r.get('short_interest'))

def _si_row_pct(r: Optional[dict[str, Any]], float_shares: Optional[float]=None) -> Optional[float]:
    if not isinstance(r, dict):
        return None
    shares = _si_row_shares(r)
    if shares is None or float_shares in (None, 0):
        return None
    return float(shares) / float(float_shares) * 100.0

def _nearest_si_row_on_or_before(raw_massive_short_interest: Any, ref_date: Optional[str]) -> Optional[dict[str, Any]]:
    if ref_date is None:
        return None
    rows = _short_interest_rows(raw_massive_short_interest)
    elig = [r for r in rows if (_si_row_date(r) or '9999-12-31') <= ref_date]
    return elig[0] if elig else None

def _prior_si_row_within_30d(raw_massive_short_interest: Any, ref_date: Optional[str]) -> Optional[dict[str, Any]]:
    cur = _nearest_si_row_on_or_before(raw_massive_short_interest, ref_date)
    cur_d = _si_row_date(cur)
    if cur_d is None:
        return None
    try:
        cur_dt = datetime.strptime(cur_d, '%Y-%m-%d').date()
    except Exception:
        return None
    for r in _short_interest_rows(raw_massive_short_interest):
        rd = _si_row_date(r)
        if rd is None or rd >= cur_d:
            continue
        try:
            rdt = datetime.strptime(rd, '%Y-%m-%d').date()
        except Exception:
            continue
        if 0 < (cur_dt - rdt).days <= 30:
            return r
    return None

def _avg_volume_20d_through_anchor(bars: list[dict[str, Any]], anchor_date: Optional[str]) -> Optional[float]:
    if not bars or anchor_date is None:
        return None
    rows = []
    for b in bars:
        d = _extract_bar_date(b) if '_extract_bar_date' in globals() else None
        v = _extract_volume_from_bar(b) if '_extract_volume_from_bar' in globals() else None
        if d is not None and v is not None and d <= anchor_date:
            rows.append((d, float(v)))
    rows.sort(key=lambda x: x[0])
    vols = [v for _, v in rows[-20:]]
    if len(vols) < 20:
        return None
    return sum(vols) / len(vols)

def _compute_dtc_independence_check(raw_massive_short_interest: Any, price_bars: list[dict[str, Any]]) -> Optional[str]:
    rows = _short_interest_rows(raw_massive_short_interest)
    if len(rows) < 2:
        return None
    cur = rows[0]
    prev = rows[1]
    cur_shares = _si_row_shares(cur)
    prev_shares = _si_row_shares(prev)
    cur_date = _si_row_date(cur)
    prev_date = _si_row_date(prev)
    if cur_shares is None or prev_shares is None or cur_date is None or prev_date is None:
        return None
    cur_adv = _avg_volume_20d_through_anchor(price_bars, cur_date)
    prev_adv = _avg_volume_20d_through_anchor(price_bars, prev_date)
    if cur_adv in (None, 0) or prev_adv in (None, 0):
        return None
    cur_dtc = float(cur_shares) / float(cur_adv)
    cf_dtc = float(cur_shares) / float(prev_adv)
    if 7.0 <= float(cur_dtc) <= 15.0 and float(cur_shares) <= float(prev_shares) * 1.02 and cf_dtc < 7.0:
        return 'waived'
    return 'not_waived'

def _compute_dtc_independence_check_at_anchor(raw_massive_short_interest: Any, price_bars: list[dict[str, Any]], anchor_date: Optional[str]) -> Optional[str]:
    if anchor_date is None:
        return None
    cur = _nearest_si_row_on_or_before(raw_massive_short_interest, anchor_date)
    prev = _prior_si_row_within_30d(raw_massive_short_interest, anchor_date)
    if not isinstance(cur, dict) or not isinstance(prev, dict):
