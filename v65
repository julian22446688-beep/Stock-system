def _latest_form4_url_from_submissions(sec_cik: Optional[str], raw_sec_submissions: Any, target_filing_date: Optional[str]=None, target_buyer_name: Optional[str]=None) -> Optional[str]:
    if not sec_cik:
        return None
    recent = _get_nested(raw_sec_submissions, 'filings', 'recent') or {}
    forms = recent.get('form')
    accessions = recent.get('accessionNumber')
    primary_docs = recent.get('primaryDocument')
    filing_dates = recent.get('filingDate')
    reporting_owners = recent.get('reportingOwner')

    if not isinstance(forms, list):
        return None

    try:
        _cik_int = str(int(str(sec_cik).strip()))
    except (ValueError, TypeError):
        _cik_int = str(sec_cik).strip().lstrip('0') or str(sec_cik).strip()

    def _buyer_tokens(name: Optional[str]) -> list[str]:
        return [tok for tok in re.split(r'[^a-z0-9]+', str(name or '').strip().lower()) if tok]

    def _filing_url_for_idx(idx: int) -> Optional[str]:
        accession = accessions[idx] if isinstance(accessions, list) and idx < len(accessions) else None
        primary_doc = primary_docs[idx] if isinstance(primary_docs, list) and idx < len(primary_docs) else None
        if accession and primary_doc:
            return f"https://www.sec.gov/Archives/edgar/data/{_cik_int}/{str(accession).replace('-', '')}/{primary_doc}"
        return None

    form4_idxs = []
    buyer_norm = str(target_buyer_name or '').strip().lower() or None
    buyer_tokens = _buyer_tokens(buyer_norm)
    owner_matched_idxs = []
    for i, form in enumerate(forms):
        if str(form).upper() != '4':
            continue
        fd = filing_dates[i] if isinstance(filing_dates, list) and i < len(filing_dates) else None
        fd = _parse_iso_date(fd)
        if target_filing_date is not None and fd != target_filing_date:
            continue
        form4_idxs.append(i)
        if buyer_tokens and isinstance(reporting_owners, list) and i < len(reporting_owners):
            owner = str(reporting_owners[i] or '').strip().lower()
            owner_tokens = [tok for tok in re.split(r'[^a-z0-9]+', owner) if tok]
            if owner_tokens and all((tok in owner_tokens for tok in buyer_tokens)):
                owner_matched_idxs.append(i)

    if not form4_idxs:
        return None

    def _form4_idx_sort_key(idx: int) -> str:
        if isinstance(filing_dates, list) and idx < len(filing_dates):
            return str(_parse_iso_date(filing_dates[idx]) or '0000-00-00')
        return '0000-00-00'

    if buyer_tokens and len(owner_matched_idxs) == 1:
        candidate_idxs = owner_matched_idxs
    elif buyer_tokens:
        candidate_idxs = sorted(form4_idxs, key=_form4_idx_sort_key, reverse=True)
        confirmed_idxs = []
        for idx in candidate_idxs:
            filing_url = _filing_url_for_idx(idx)
            filing_text = _safe_call(sec_get_filing_text, filing_url) if filing_url else None
            if isinstance(filing_text, str):
                txt_norm = re.sub(r'[^a-z0-9]+', ' ', filing_text.lower())
                if buyer_tokens and all((tok in txt_norm for tok in buyer_tokens)):
                    confirmed_idxs.append(idx)
        if len(confirmed_idxs) != 1:
            return None
        candidate_idxs = confirmed_idxs
    else:
        candidate_idxs = sorted(form4_idxs, key=_form4_idx_sort_key, reverse=True)

    i = candidate_idxs[0]
    return _filing_url_for_idx(i)

