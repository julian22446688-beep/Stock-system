    out['net_cash_flag'] = None if out['cash'] is None or out['total_debt'] is None else out['cash'] > out['total_debt']
    ebitda = _sum_latest_quarters(income_rows, 'ebitda', 4)
    if out['cash'] is not None and out['total_debt'] is not None and ebitda not in (None, 0):
        out['net_debt_ebitda'] = (out['total_debt'] - out['cash']) / ebitda
    else:
        out['net_debt_ebitda'] = None
    out['price_to_sales'] = _latest_non_null([_to_float(ratios_ttm.get('priceToSalesRatio')), _to_float(km_ttm.get('priceToSalesRatio')), price_to_sales_fallback])
    gross_profit_ttm = _sum_latest_quarters(income_rows, 'grossProfit', 4)
    revenue_ttm = _sum_latest_quarters(income_rows, 'revenue', 4)
    total_assets_cur = _to_float(balance_source[0].get('totalAssets')) if len(balance_source) >= 1 else None
    if gross_profit_ttm is None:
        _rev_for_gp = _sum_latest_quarters(income_rows, 'revenue', 4)
        _cogs = _sum_latest_quarters(income_rows, 'costOfRevenue', 4)
        if _rev_for_gp is not None and _cogs is not None:
            gross_profit_ttm = float(_rev_for_gp) - float(_cogs)
    if gross_profit_ttm is not None and total_assets_cur not in (None, 0):
        out['gpa_ratio'] = gross_profit_ttm / total_assets_cur
    else:
        out['gpa_ratio'] = None
    gross_margin = _latest_non_null([
        _to_float(ratios_ttm.get('grossProfitMargin')),
        _to_float(km_ttm.get('grossProfitMargin')),
    ])
    if gross_margin is None and gross_profit_ttm is not None and revenue_ttm not in (None, 0):
        gross_margin = gross_profit_ttm / revenue_ttm
    if gross_margin is not None and abs(float(gross_margin)) > 1.0:
        gross_margin = float(gross_margin) / 100.0
    out['_requires_gpa_peer_benchmark'] = None if gross_margin is None else float(gross_margin) < 0.35
    out['valuation_soft_flag'] = None
    return out

def parse_sec_filing_section(sec_cik: Optional[str], raw_sec_submissions: Any, latest_buy_date: Optional[str]) -> dict[str, Any]:
    fields = ['sec_cik', 'sec_recent_form4_count_240d', 'sec_last_form4_accession', 'sec_last_form4_url', 'sec_secondary_offering_flag']
    out = _none_dict(fields)
    out['sec_cik'] = sec_cik
    if latest_buy_date is None:
        out['sec_secondary_offering_flag'] = False
    recent = _get_nested(raw_sec_submissions, 'filings', 'recent') or {}
    forms = recent.get('form') if isinstance(recent, dict) else None
    accessions = recent.get('accessionNumber') if isinstance(recent, dict) else None
    primary_docs = recent.get('primaryDocument') if isinstance(recent, dict) else None
    filing_dates = recent.get('filingDate') if isinstance(recent, dict) else None

    def _sec_archives_url(accession: Any, primary_doc: Any) -> Optional[str]:
        if not (sec_cik and accession and primary_doc):
            return None
        try:
            _cik_int = str(int(str(sec_cik).strip()))
        except (ValueError, TypeError):
            _cik_int = str(sec_cik).strip().lstrip('0') or str(sec_cik).strip()
        return f"https://www.sec.gov/Archives/edgar/data/{_cik_int}/{str(accession).replace('-', '')}/{primary_doc}"

    def _secondary_offering_common_equity_confirmation(filing_text: Optional[str]) -> Optional[bool]:
        if not isinstance(filing_text, str) or not filing_text.strip():
            return None
        txt = filing_text
        txt = re.sub(r'(?is)<script[^>]*>.*?</script>', ' ', txt)
        txt = re.sub(r'(?is)<style[^>]*>.*?</style>', ' ', txt)
        txt = re.sub(r'(?i)</p\s*>', '\n', txt)
        txt = re.sub(r'(?i)<br\s*/?>', '\n', txt)
        txt = re.sub(r'(?i)</div\s*>', '\n', txt)
        txt = re.sub(r'(?i)</td\s*>', '\t', txt)
        txt = re.sub(r'(?i)<[^>]+>', ' ', txt)
        txt = html_lib.unescape(txt).replace('\xa0', ' ')
        txt = re.sub(r'\s+', ' ', txt).strip().lower()
        has_offering = any((term in txt for term in [
            'offering',
            'offer and sale',
            'offered hereby',
            'sale of',
            'issuance',
            'issued',
            'prospectus supplement',
            'prospectus',
            'at-the-market offering',
            'at the market offering',
            'underwritten public offering',
            'underwriting',
            'registered direct offering',
        ]))
        has_common_equity = any((term in txt for term in [
            'common stock',
            'common shares',
            'shares of common stock',
            'shares of our common stock',
            'ordinary shares',
            'ordinary share',
        ]))
        has_excluded_only = any((term in txt for term in [
            'senior notes',
            'convertible notes',
            'notes due',
            'debt securities',
            'preferred stock',
            'preferred shares',
            'warrants',
            'rights offering',
            'units consisting of',
            'debt offering',
            'preferred equity',
        ]))
        has_resale_markers = any((term in txt for term in [
            'selling stockholder',
            'selling stockholders',
            'resale of',
            'resale prospectus',
        ]))
        has_no_issuer_proceeds = any((term in txt for term in [
            'no proceeds to us',
            'no proceeds to the issuer',
            'we will not receive any proceeds',
            'the company will not receive any proceeds',
            'issuer will not receive any proceeds',
            'we will not receive proceeds',
        ]))
        has_primary_issuer_equity = any((term in txt for term in [
            'proceeds to us',
            'proceeds to the issuer',
            'we are offering',
            'we may offer',
            'issuance by us',
            'newly issued',
            'shares offered by us',
            'sale by us',
            'ordinary shares offered by us',
            'at-the-market offering',
            'at the market offering',
            'underwritten public offering',
        ])) and not has_no_issuer_proceeds
        has_resale_only = has_resale_markers and (has_no_issuer_proceeds or not has_primary_issuer_equity)
        if has_resale_only:
            return False
        if has_excluded_only and not has_common_equity:
            return False
        if has_offering and has_common_equity and has_primary_issuer_equity:
            return True
        if has_offering and has_common_equity:
            return None
        return None

    if isinstance(forms, list):
        cutoff = date.today() - timedelta(days=240)
        form4_idxs = []
        for i, form in enumerate(forms):
            if str(form).upper() != '4':
                continue
            fd = filing_dates[i] if isinstance(filing_dates, list) and i < len(filing_dates) else None
            fd_parsed = _parse_iso_date(fd)
            if fd_parsed:
                try:
                    if datetime.strptime(fd_parsed, '%Y-%m-%d').date() >= cutoff:
                        form4_idxs.append(i)
                except Exception:
                    pass
        out['sec_recent_form4_count_240d'] = len(form4_idxs)
        if form4_idxs:
            def _form4_idx_sort_key(idx: int) -> str:
                if isinstance(filing_dates, list) and idx < len(filing_dates):
                    return str(_parse_iso_date(filing_dates[idx]) or '0000-00-00')
                return '0000-00-00'
            form4_idxs = sorted(form4_idxs, key=_form4_idx_sort_key, reverse=True)
            i = form4_idxs[0]
            accession = accessions[i] if isinstance(accessions, list) and i < len(accessions) else None
            primary_doc = primary_docs[i] if isinstance(primary_docs, list) and i < len(primary_docs) else None
            out['sec_last_form4_accession'] = accession
            out['sec_last_form4_url'] = _sec_archives_url(accession, primary_doc)
        if latest_buy_date is not None:
            try:
                insider_dt = datetime.strptime(latest_buy_date, '%Y-%m-%d').date()
            except Exception:
                insider_dt = None
            if insider_dt is not None and isinstance(filing_dates, list):
                candidate_idxs = []
                for i, form in enumerate(forms):
                    form_u = str(form).upper()
                    is_candidate = (
                        form_u in {
                            '424B1', '424B2', '424B3', '424B4', '424B5',
                            'S-1', 'S-1/A',
                            'S-3', 'S-3/A', 'S-3ASR',
                            'S-11', 'S-11/A',
                            'POS AM', 'POSASR'
                        }
                    )
                    if not is_candidate:
                        continue
                    fd = filing_dates[i] if i < len(filing_dates) else None
                    fd_parsed = _parse_iso_date(fd)
                    if not fd_parsed:
                        continue
                    try:
                        if datetime.strptime(fd_parsed, '%Y-%m-%d').date() > insider_dt:
                            candidate_idxs.append(i)
                    except Exception:
                        pass
                if not candidate_idxs:
                    out['sec_secondary_offering_flag'] = False
                else:
                    found = False
                    ambiguous = False
                    for i in candidate_idxs:
                        accession = accessions[i] if isinstance(accessions, list) and i < len(accessions) else None
                        primary_doc = primary_docs[i] if isinstance(primary_docs, list) and i < len(primary_docs) else None
                        filing_url = _sec_archives_url(accession, primary_doc)
                        filing_text = _safe_call(sec_get_filing_text, filing_url) if filing_url else None
                        confirmed = _secondary_offering_common_equity_confirmation(filing_text)
                        if confirmed is True:
                            found = True
                            break
                        if confirmed is None:
                            ambiguous = True
                    if found:
                        out['sec_secondary_offering_flag'] = True
                    elif ambiguous:
                        out['sec_secondary_offering_flag'] = None
                    else:
                        out['sec_secondary_offering_flag'] = False
    return out

