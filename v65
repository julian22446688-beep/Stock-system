def _quarter_end_for_date(d: date) -> date:
    q = (d.month - 1) // 3 + 1
    if q == 1:
        return date(d.year, 3, 31)
    if q == 2:
        return date(d.year, 6, 30)
    if q == 3:
        return date(d.year, 9, 30)
    return date(d.year, 12, 31)

def _quarter_end_on_or_before(ref_date_str: Optional[str]) -> Optional[date]:
    d = _parse_iso_date(ref_date_str) if '_parse_iso_date' in globals() else None
    if d is None:
        return None
    try:
        dd = datetime.strptime(d, '%Y-%m-%d').date()
    except Exception:
        return None
    qe = _quarter_end_for_date(dd)
    if qe > dd:
        prev_month = qe.month - 3
        year = qe.year if prev_month > 0 else qe.year - 1
        month = prev_month if prev_month > 0 else prev_month + 12
        qe = _quarter_end_for_date(date(year, month, 1))
    return qe

def _sec_13f_zip_url_for_quarter(qe: date) -> Optional[str]:
    page_html = _safe_call(_http_get_text, 'https://www.sec.gov/data-research/sec-markets-data/form-13f-data-sets', headers=_sec_headers())
    if not isinstance(page_html, str) or not page_html:
        return None
    links = re.findall(r'href="([^"]+form13f\.zip)"[^>]*>([^<]+)</a>', page_html, flags=re.I)
    for href, label in links:
        lbl = ' '.join(label.split())
        if qe.year >= 2024:
            if qe.month == 12 and str(qe.year) in lbl and 'December' in lbl:
                return href if href.startswith('http') else 'https://www.sec.gov' + href
            if qe.month == 9 and str(qe.year) in lbl and 'September October November' in lbl:
                return href if href.startswith('http') else 'https://www.sec.gov' + href
            if qe.month == 6 and str(qe.year) in lbl and 'June July August' in lbl:
                return href if href.startswith('http') else 'https://www.sec.gov' + href
            if qe.month == 3 and str(qe.year) in lbl and 'March April May' in lbl:
                return href if href.startswith('http') else 'https://www.sec.gov' + href
        else:
            qn = ((qe.month - 1) // 3) + 1
            if f'{qe.year} Q{qn}' in lbl:
                return href if href.startswith('http') else 'https://www.sec.gov' + href
    return None

def _sec_13f_zip_path_for_quarter(qe: date) -> str:
    return os.path.join(SEC_13F_CACHE_DIR, f'{qe.isoformat()}_form13f.zip')

def _download_cached_13f_zip(qe: date) -> Optional[str]:
    path = _sec_13f_zip_path_for_quarter(qe)
    if os.path.exists(path):
        return path
    url = _sec_13f_zip_url_for_quarter(qe)
    if not url:
        return None
    payload = _safe_call(_http_get_bytes, url, headers=_sec_headers())
    if not isinstance(payload, (bytes, bytearray)) or not payload:
        return None
    _write_bytes_file(path, bytes(payload))
    return path

def _csv_rows_from_zip_member(zf: zipfile.ZipFile, member: str) -> list[dict[str, Any]]:
    raw = zf.read(member)
    txt = raw.decode('utf-8', errors='ignore')
    delimiter = '	' if member.lower().endswith('.tsv') else ','
    return list(csv.DictReader(io.StringIO(txt), delimiter=delimiter))

def _xml_holdings_rows_from_zip_member(zf: zipfile.ZipFile, member: str) -> list[dict[str, Any]]:
    try:
        root = ET.fromstring(zf.read(member))
    except Exception:
        return []
    rows = []
    for info in root.findall('.//{*}infoTable') + root.findall('.//infoTable'):
        row = {}
        for child in info:
            tag = child.tag.split('}')[-1]
            if list(child):
                for sub in child:
                    row[sub.tag.split('}')[-1]] = (sub.text or '').strip()
            else:
                row[tag] = (child.text or '').strip()
        rows.append(row)
    return rows

def _sec_13f_dataset_rows_for_quarter(qe: date) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
    zip_path = _download_cached_13f_zip(qe)
    if not zip_path or not os.path.exists(zip_path):
        return ([], [])
    try:
        with zipfile.ZipFile(zip_path, 'r') as zf:
            names = zf.namelist()
            holdings = []
            subs = []
            for name in names:
                low = name.lower()
                if low.endswith(('.tsv', '.csv')):
                    rows = _csv_rows_from_zip_member(zf, name)
                    if 'info' in low or 'hold' in low:
                        holdings = rows
                    elif 'sub' in low or 'cover' in low or 'submission' in low:
                        subs = rows
                elif low.endswith('.xml') and ('infotable' in low or 'info' in low):
                    holdings = _xml_holdings_rows_from_zip_member(zf, name)
            return (holdings, subs)
    except Exception:
        return ([], [])

def _row_get_any(row: dict[str, Any], keys: list[str]) -> Any:
    for k in keys:
        if k in row and row.get(k) not in (None, ''):
            return row.get(k)
        for rk, rv in row.items():
            if str(rk).lower() == k.lower() and rv not in (None, ''):
                return rv
    return None

def _manager_key_from_13f_row(row: dict[str, Any]) -> Optional[str]:
    return _latest_non_null([_row_get_any(row, ['cik', 'manager_cik', 'filingmanager_cik']), _row_get_any(row, ['accession_number', 'accessionnumber', 'accession']), _row_get_any(row, ['name', 'filingmanager_name', 'manager_name'])])

def _issuer_match_13f_row(row: dict[str, Any], issuer_cusip: Optional[str], ticker: Optional[str]) -> bool:
    row_cusip = _row_get_any(row, ['cusip'])
    if issuer_cusip and row_cusip:
        lhs = re.sub(r'[^A-Za-z0-9]', '', str(row_cusip).upper())
        rhs = re.sub(r'[^A-Za-z0-9]', '', str(issuer_cusip).upper())
        if lhs and rhs and (lhs.startswith(rhs[:8]) or rhs.startswith(lhs[:8])):
            return True
    row_ticker = _row_get_any(row, ['ticker', 'symbol'])
    if ticker and row_ticker and str(row_ticker).strip().upper() == str(ticker).strip().upper():
        return True
    return False

def _shares_from_13f_row(row: dict[str, Any]) -> Optional[float]:
    return _to_float(_row_get_any(row, ['sshPrnamt', 'sshprnamt']))

def _13f_positions_for_issuer(qe: date, issuer_cusip: Optional[str], ticker: Optional[str]) -> dict[str, float]:
    holdings, _subs = _sec_13f_dataset_rows_for_quarter(qe)
    out: dict[str, float] = {}
    for r in holdings:
        if not isinstance(r, dict) or not _issuer_match_13f_row(r, issuer_cusip, ticker):
            continue
        mgr = _manager_key_from_13f_row(r)
        sh = _shares_from_13f_row(r)
        if mgr and sh is not None:
            out[str(mgr)] = out.get(str(mgr), 0.0) + float(sh)
    return out

def _compute_institutional_convergence_result(issuer_cusip: Optional[str], ticker: Optional[str], float_shares: Optional[float], buy_date: Optional[str]) -> tuple[Optional[bool], Optional[float]]:
    if float_shares in (None, 0) or buy_date is None:
        return (None, None)
    try:
        buy_dt = datetime.strptime(buy_date, '%Y-%m-%d').date()
    except Exception:
        return (None, None)
    qe = _quarter_end_on_or_before(buy_date)
    if qe is None:
        return (None, None)
    days_since_qe = (buy_dt - qe).days
    prev_qe = _quarter_end_on_or_before((qe - timedelta(days=1)).isoformat())
    cur_map = _13f_positions_for_issuer(qe, issuer_cusip, ticker)
    prev_map = _13f_positions_for_issuer(prev_qe, issuer_cusip, ticker) if prev_qe is not None else {}
    if not cur_map:
        return (None, float(days_since_qe))
    qualifying = 0
    for mgr, cur_shares in cur_map.items():
        if float(cur_shares) < float(float_shares) * 0.01:
            continue
        prev_shares = float(prev_map.get(mgr, 0.0) or 0.0)
        initiated = prev_shares == 0.0 and cur_shares > 0.0
        increased = prev_shares > 0.0 and float(cur_shares) >= prev_shares * 1.20
        if initiated or increased:
            qualifying += 1
    return (qualifying >= 2, float(days_since_qe))

def massive_list_option_contracts(underlying: str, as_of: str, limit: int=1000) -> list[dict[str, Any]]:
    url = f'{POLYGON_BASE}/v3/reference/options/contracts'
    params = {'underlying_ticker': underlying, 'contract_type': 'call', 'as_of': as_of, 'limit': limit, 'apiKey': MASSIVE_API_KEY}
    out = []
    while True:
        payload = _http_get_json(url, params=params)
        results = payload.get('results') if isinstance(payload, dict) else None
        if isinstance(results, list):
            out.extend(results)
        next_url = payload.get('next_url') if isinstance(payload, dict) else None
        if not next_url:
            break
        url = next_url
        params = {'apiKey': MASSIVE_API_KEY}
    return out

