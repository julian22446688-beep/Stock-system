def _quintile_rank(values: list[float], value: float) -> int:
    if not values:
        return 3
    vals = sorted(values)
    pct = sum((1 for x in vals if x <= value)) / len(vals)
    if pct <= 0.2:
        return 1
    if pct <= 0.4:
        return 2
    if pct <= 0.6:
        return 3
    if pct <= 0.8:
        return 4
    return 5


